# --- Drizzle / Postgres ------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/underpin"

# --- Corsair ------------------------------------------------------------------
# See AGENT_PROMPT.md / README.md in the corsairdev/google-demo reference repo
# for the full setup sequence (pnpm corsair setup / auth / auth --webhooks).
CORSAIR_KEK="<base64 key, e.g. `openssl rand -base64 32`>"
TENANT_ID="dev"

# Corsair's MCP server URL, for the agent-chat bonus feature. The reference
# repo doesn't demonstrate this path (it only shows tRPC + direct API calls)
# — confirm via `pnpm corsair --help` or the Corsair dashboard.
CORSAIR_MCP_URL=

# --- Anthropic ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Ngrok (optional, for local webhook testing) ------------------------------
NGROK_AUTHTOKEN=
